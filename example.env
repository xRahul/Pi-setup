PIHOLE_ETC_PATH=
PIHOLE_ETC_DNSMASQ_PATH=
# Note: Local DNS is managed via pihole.env as FTLCONF_dns_hosts
PIHOLE_LOCAL_DNS=10.8.1.48 pihole.pi.rahulja.in;10.8.1.48 dash.pi.rahulja.in

# DNSCrypt-Proxy (Upstream for Pi-hole)
# Config lives in ./dnscrypt-proxy/dnscrypt-proxy.toml
